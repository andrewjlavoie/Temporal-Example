%% E-Commerce Order Workflow — Failure at Shipping, Compensation Triggered
%% View at https://mermaid.live or in any Mermaid-compatible renderer

sequenceDiagram
    participant C as Client
    participant W as OrderWorkflow
    participant P as Payment Service
    participant I as Inventory Service
    participant S as Shipping Service

    C->>W: Start Workflow (order-ORD-12345)
    Note over W: Status: PENDING

    rect rgb(200, 235, 200)
        Note over W: Steps 1-2 Succeed
        W->>P: process_payment($2,548.99)
        P-->>W: ✅ txn_abc123
        Note over W: Status: PAYMENT_PROCESSED

        W->>I: reserve_inventory([MacBook, Sleeve])
        I-->>W: ✅ res_def456
        Note over W: Status: INVENTORY_RESERVED
    end

    rect rgb(255, 200, 200)
        Note over W: Step 3 Fails
        W->>S: ship_package()
        S-->>W: ❌ Address validation failed
        Note over W: Status: FAILED
    end

    rect rgb(255, 235, 200)
        Note over W: Saga Compensation (reverse order)

        W->>I: release_inventory(res_def456)
        I-->>W: ✅ Inventory released
        Note over W: Compensation 1/2 ✓

        W->>P: refund_payment(txn_abc123, $2,548.99)
        P-->>W: ✅ Payment refunded
        Note over W: Compensation 2/2 ✓

        Note over W: Status: COMPENSATED
    end

    W-->>C: {status: compensated, reason: "Address validation failed"}
