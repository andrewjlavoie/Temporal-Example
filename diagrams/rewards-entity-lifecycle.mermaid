%% Rewards Program — Entity Workflow Lifecycle
%% View at https://mermaid.live or in any Mermaid-compatible renderer

stateDiagram-v2
    [*] --> Enrolled: Start Workflow
    
    state "BASIC (0-499 pts)" as Basic {
        [*] --> WaitingBasic: Welcome bonus applied
        WaitingBasic --> WaitingBasic: Signal: add_points
        WaitingBasic --> WaitingBasic: Signal: redeem_points
        WaitingBasic --> WaitingBasic: Query: get_status / get_level
    }

    state "GOLD (500-999 pts)" as Gold {
        [*] --> WaitingGold
        WaitingGold --> WaitingGold: Signal: add_points
        WaitingGold --> WaitingGold: Signal: redeem_points
        WaitingGold --> WaitingGold: Query: get_status / get_level
    }

    state "PLATINUM (1000+ pts)" as Platinum {
        [*] --> WaitingPlat
        WaitingPlat --> WaitingPlat: Signal: add_points
        WaitingPlat --> WaitingPlat: Signal: redeem_points
        WaitingPlat --> WaitingPlat: Query: get_status / get_level
    }

    Enrolled --> Basic: Initial tier assignment
    Basic --> Gold: Points >= 500 (tier upgrade notification)
    Gold --> Basic: Points < 500 after redemption (tier downgrade)
    Gold --> Platinum: Points >= 1000 (tier upgrade notification)
    Platinum --> Gold: Points < 1000 after redemption (tier downgrade)
    
    Basic --> [*]: Signal: leave_program → offboarding
    Gold --> [*]: Signal: leave_program → offboarding
    Platinum --> [*]: Signal: leave_program → offboarding

    note right of Basic
        Continue-As-New after 1000 events
        (resets history, preserves state)
    end note
